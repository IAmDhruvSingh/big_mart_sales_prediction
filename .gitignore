# =============================================================================
# Data files  —  keep raw/processed data out of version control
# =============================================================================
data/*.csv
data/*.xlsx
data/*.parquet
data/*.json
!data/.gitkeep

# =============================================================================
# Saved model artefacts
# =============================================================================
models/
*.joblib
*.pkl

# =============================================================================
# Jupyter Notebook checkpoints
# =============================================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# =============================================================================
# Python caches & build artefacts
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# Reports / generated outputs (optional — remove if you want to track results)
# =============================================================================
reports/*.png
reports/*.pdf
reports/predictions.csv

# =============================================================================
# OS / IDE artefacts
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
